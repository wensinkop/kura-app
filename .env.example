# Supabase connection — copy this file to ".env" and fill in real values.
# The real ".env" is gitignored and must never be committed.
#
# Find these in the Supabase dashboard:
#   Project Settings -> Data API  (Project URL)
#   Project Settings -> API Keys  (publishable / anon key)

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here
